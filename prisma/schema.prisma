// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  DISPATCHER
  ADMIN
}

enum FlightStatus {
  QUEUED
  ACTIVE
  COMPLETED
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  flights   Flight[]
  member    Member?
}

enum MemberStatus {
  AKTIV
  INAKTIV
}

model Member {
  id          Int           @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String?       @unique
  status      MemberStatus? @default(AKTIV)
  birthDate   DateTime
  hasLicense  Boolean       @default(false)
  createdAt   DateTime      @default(now())

  userId      Int?          @unique
  user        User?         @relation(fields: [userId], references: [id])

  flights          Flight[]  @relation("PilotFlights")
  instructorFlights Flight[] @relation("InstructorFlights")
}

model Aircraft {
  id            Int       @id @default(autoincrement())
  model         String
  registration  String    @unique
  yearBuilt     Int?
  isTwoSeater   Boolean   @default(false)
  isMotorized   Boolean   @default(false)
  createdAt     DateTime  @default(now())

  flights       Flight[]
}

model Flight {
  id           Int       @id @default(autoincrement())

  status       FlightStatus @default(QUEUED)

  startTime    DateTime?
  endTime      DateTime?

  departureLocation  String?
  arrivalLocation    String?

  launchType   String?
  flightType   String?
  pilotFunction String?   // PIC_SOLO, PIC_WITH_COPILOT, DUAL_STUDENT, DUAL_INSTRUCTOR

  instructorId Int?
  instructor   Member?   @relation("InstructorFlights", fields: [instructorId], references: [id])

  notes        String?

  createdAt    DateTime  @default(now())
  createdById  Int?
  createdBy    User?     @relation(fields: [createdById], references: [id])

  memberId     Int
  member       Member    @relation("PilotFlights", fields: [memberId], references: [id])

  aircraftId   Int
  aircraft     Aircraft  @relation(fields: [aircraftId], references: [id])
}